# Backend runtime
APP_ENV=dev
API_PORT=8010

# Local models (requires Ollama running: https://ollama.com)
OLLAMA_BASE_URL=http://127.0.0.1:11434
EMBED_MODEL=nomic-embed-text
CHAT_MODEL=mistral

# Data locations
SQLITE_PATH=./data/local_search.db
TRACKING_DB_PATH=./data/query_tracking.db
CHROMA_DIR=./data/chroma_store

# Path to the source Outlook SQLite exported from Dev1 (used by Admin Load).
# Leave blank to let the backend auto-detect the default Dev1 path.
# Example: SOURCE_SQLITE_PATH=C:\\Users\\you\\outlook\\local_search.db
SOURCE_SQLITE_PATH=
